# San Enrique LGU Scholarship - Apache hardening

Options -Indexes
AddDefaultCharset UTF-8

<IfModule mod_php.c>
php_value upload_max_filesize 32M
php_value post_max_size 40M
php_value max_file_uploads 30
php_value max_input_time 300
php_value max_execution_time 300
</IfModule>

<IfModule mod_rewrite.c>
RewriteEngine On

# Allow SSL verification challenges
RewriteRule (^|/)\.well-known/ - [L]

# Block hidden files/folders
RewriteRule (^|/)\.(?!well-known/) - [F,L]

# Block direct web access to non-public application folders
RewriteRule ^(?:app|vendor|backups|scripts|tests)/ - [F,L,NC]

# Block direct access to sensitive file types
RewriteRule \.(?:sql|log|ini|env)$ - [F,L,NC]

# Block direct access to project meta files
RewriteRule ^(?:composer\.(?:json|lock)|README\.md)$ - [F,L,NC]

# Allow direct access to the real public web root if it is requested explicitly.
RewriteRule ^public/ - [L]

# Mirror the public static/files endpoints when the project root is accessed directly.
RewriteRule ^assets/(.+)$ public/assets/$1 [QSA,L,NC]
RewriteRule ^uploads/(.+)$ public/files.php?path=$1 [QSA,L,NC]

# Route all remaining root-level requests through the public front controller.
RewriteRule ^$ public/index.php?__root_route= [QSA,L]
RewriteRule ^(.+)$ public/index.php?__root_route=$1 [QSA,L]
</IfModule>

<IfModule mod_headers.c>
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "SAMEORIGIN"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Permissions-Policy "camera=(self), microphone=(), geolocation=()"
</IfModule>

<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType text/css "access plus 7 days"
ExpiresByType application/javascript "access plus 7 days"
ExpiresByType application/x-javascript "access plus 7 days"
ExpiresByType image/jpeg "access plus 30 days"
ExpiresByType image/png "access plus 30 days"
ExpiresByType image/webp "access plus 30 days"
ExpiresByType image/svg+xml "access plus 30 days"
ExpiresByType image/x-icon "access plus 30 days"
</IfModule>
