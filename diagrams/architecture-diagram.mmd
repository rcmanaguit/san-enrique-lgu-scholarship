flowchart TB
    %% Complete Architecture Diagram - San Enrique LGU Scholarship System

    subgraph CLIENTS[Client Layer]
        C1[Applicant Browser]
        C2[Admin Browser]
        C3[Staff Browser]
    end

    subgraph WEB[Web/Application Layer (Apache + PHP)]
        R[Routing / Entry Pages]
        M1[Auth and Session Module]
        M2[Application Wizard Module]
        M3[Document and Photo Upload Module]
        M4[Review and Status Management Module]
        M5[Disbursement Module]
        M6[Notification and SMS Module]
        M7[Reports and Export Module]
        M8[Announcements and Configuration Module]
        M9[Global Search and Realtime Module]
        U[Utility Layer (includes/functions, validation, helpers)]
    end

    subgraph DATA[Data Layer (MySQL/MariaDB)]
        D1[(users)]
        D2[(applications)]
        D3[(application_documents)]
        D4[(requirement_templates)]
        D5[(application_periods)]
        D6[(disbursements)]
        D7[(notifications)]
        D8[(sms_templates)]
        D9[(sms_logs)]
        D10[(audit_logs)]
        D11[(announcements)]
        D12[(otp_codes)]
        D13[(application_wizard_drafts)]
        D14[(barangays)]
    end

    subgraph FILES[File Storage Layer]
        F1[(uploads/photos)]
        F2[(uploads/documents)]
        F3[(uploads/tmp)]
    end

    subgraph INTEGRATIONS[External Integrations]
        X1[SMS Provider API]
    end

