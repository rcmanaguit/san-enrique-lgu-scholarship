    %% DFD Level 0 (Context)
    %% External entities <-> Main system <-> Core data stores

    subgraph EXTERNALS[External Entities]
        AP[Applicant]
        AS[Admin/Staff]
        SG[SMS Gateway]
    end

    SYS((0.0 Scholarship Records Management System))

    subgraph STORES[Data Stores]
        D1[(D1 Users)]
        D2[(D2 Applications)]
        D3[(D3 Application Documents)]
        D4[(D4 Requirement Templates)]
        D5[(D5 Application Periods)]
        D6[(D6 Disbursements)]
        D7[(D7 Notifications)]
        D8[(D8 SMS Templates)]
        D9[(D9 SMS Logs)]
        D10[(D10 Audit Logs)]
        D11[(D11 Announcements)]
        D12[(D12 OTP Codes)]
        D13[(D13 Application Wizard Drafts)]
        D14[(D14 Barangays)]
