{
    "name": "san-enrique/lgu-scholarship-system",
    "description": "San Enrique LGU Scholarship Records Management System",
    "type": "project",
    "license": "proprietary",
    "scripts": {
        "test": "php vendor/bin/phpunit --colors=always",
        "phpstan": "php vendor/bin/phpstan analyse --memory-limit=1G",
        "cs:check": "php vendor/bin/php-cs-fixer fix --dry-run --diff --verbose",
        "cs:fix": "php vendor/bin/php-cs-fixer fix --verbose"
    },
    "require": {
        "dompdf/dompdf": "^3.1",
        "phpoffice/phpword": "^1.4",
        "phpoffice/phpspreadsheet": "^5.5",
        "vlucas/phpdotenv": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "phpstan/phpstan": "^2.1",
        "friendsofphp/php-cs-fixer": "^3.94"
    }
}
